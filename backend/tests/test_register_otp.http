# ===========================================
# TESTS API AUTHENTIFICATION AVEC SMS OTP - MAZADPAY
# ===========================================
#
# FLOW COMPLET SMS:
# 1. Register -> Envoi automatique OTP via Twilio
# 2. Send OTP -> Relance si expiré/rate limit
# 3. Verify OTP -> Validation code SMS reçu
# 4. Login -> Accès avec PIN (seulement après OTP vérifié)
#
# CONFIGURATION TWILIO REQUISE:
# - TWILIO_ACCOUNT_SID
# - TWILIO_AUTH_TOKEN  
# - TWILIO_PHONE_NUMBER
#
# VALIDATIONS PIN:
# - Valide: 1957, 2468, 9753 (mélangés)
# - Rejeté: 1234, 1111 (séquentiel/répétitif)
#
# CODES OTP:
# - Développement: 123456 (fixe via DEV_OTP_CODE)
# - Production: Aléatoire 4-6 chiffres envoyé par SMS
#
# ===========================================

@baseUrl = http://localhost:8082/v1/api
@testPhone = +222323232326
@devOtpCode = 123456
@smsTestPhone = +22237141002

### ========================
### 1. Register New User (avec PIN fort)
### ========================
# @name registerUser
POST {{baseUrl}}/auth/register
Content-Type: application/json
{
    "phone": "{{testPhone}}",
    "pin": "1957",
    "full_name": "usertest added",
    "email": "test_api.med@example.com",
    "city": "Nouakchott"
}

### ========================
### 2. Send OTP (for registration)
### ========================
# @name sendOTP
POST {{baseUrl}}/auth/otp/send
Content-Type: application/json

{
    "phone": "{{testPhone}}",
    "purpose": "register"
}

### ========================
### 3. Verify OTP (code de développement: {{devOtpCode}})
### ========================
# @name verifyOTP
POST {{baseUrl}}/auth/otp/verify
Content-Type: application/json

{
    "phone": "{{testPhone}}",
    "code": "{{devOtpCode}}",
    "purpose": "register"
}

### ========================
### 4. Login (après OTP vérifié)
### ========================
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "phone": "{{testPhone}}",
    "pin": "1957"
}

### ========================
### 5. Get User Profile (avec token du login)
### ========================
# @name getProfile
GET {{baseUrl}}/users/me
Authorization: Bearer {{login.response.body.data.token}}

### ========================
### TEST COMPLET: Register + SMS OTP + Login
### ========================
@flowPhone = +222323232326

# @name fullFlowRegister
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "phone": "{{flowPhone}}",
    "pin": "2468",
    "full_name": "test full flow",
    "email": "full_flow{{$randomInt}}@example.com",
    "city": "Nouakchott"
}

###
# @name fullFlowSendOTP
POST {{baseUrl}}/auth/otp/send
Content-Type: application/json

{
    "phone": "{{flowPhone}}",
    "purpose": "register"
}

###
# @name fullFlowVerifyOTP
POST {{baseUrl}}/auth/otp/verify
Content-Type: application/json

{
    "phone": "{{flowPhone}}",
    "code": "{{devOtpCode}}",
    "purpose": "register"
}

###
# @name fullFlowLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "phone": "{{flowPhone}}",
    "pin": "2468"
}

