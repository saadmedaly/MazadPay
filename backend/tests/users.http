### Variables
@baseUrl = http://localhost:8082/v1/api
@adminToken = {{$dotenv ADMIN_TOKEN}}

### 1. Register a new regular user
# @name registerUser
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "phone": "22233334444",
    "pin": "1234"
}

### 2. Login as the regular user (will fail if OTP not verified, but let's assume DEV bypass or we verify manually via DB)
# @name loginUser
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "phone": "22233334444",
    "pin": "1234"
}

### 3. Generate Admin Invitation (Requires Admin Token)
# @name generateInvitation
POST {{baseUrl}}/admin/invitations
Content-Type: application/json
Authorization: Bearer {{adminToken}}

### 4. Register new Admin using the generated token (Replace the token below)
# @name registerAdmin
POST {{baseUrl}}/auth/register-admin
Content-Type: application/json

{
    "token": "{{generateInvitation.response.body.data.token}}",
    "phone": "22299998888",
    "full_name": "New Admin User",
    "email": "newadmin@mazadpay.com",
    "pin": "1234"
}
