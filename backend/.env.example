# ── Application ─────────────────────────────────
APP_ENV=development
APP_PORT=8082
APP_NAME=MazadPay

# ── PostgreSQL ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=mazadpay
DB_PASSWORD=mazadpay_secret
DB_NAME=mazadpay
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTES=30

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_OTP_TTL_MINUTES=5
REDIS_RATE_LIMIT_WINDOW_SECONDS=900
REDIS_RATE_LIMIT_MAX_ATTEMPTS=3

# ── JWT ──────────────────────────────────────────
JWT_SECRET=change_me_in_production_minimum_32_characters
JWT_EXPIRY_HOURS=72
JWT_REFRESH_EXPIRY_DAYS=30

# ── Cloudflare R2 / S3 ───────────────────────────
R2_ENDPOINT=xxxxxxxx.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET_MEDIA=mazadpay-media
R2_PUBLIC_URL=https://pub-xxxxxx.r2.dev

# ── Twilio SMS ──────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OTP_CODE_LENGTH=4

# ── Firebase Cloud Messaging (FCM) ────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./configs/firebase-service-account.json
# Alternative: FCM_SERVICE_ACCOUNT_JSON (contenu JSON directement)

# ── Business Rules ───────────────────────────────
BID_MIN_INCREMENT=100
INSURANCE_DEFAULT_AMOUNT=500
PAYMENT_DEADLINE_HOURS=48
